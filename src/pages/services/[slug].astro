---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  const services = [
    {
      slug: "depannage-plomberie",
      title: "Dépannage plomberie",
      description: "Intervention rapide pour toutes vos urgences plomberie : fuite d'eau, robinet qui goutte, WC bouché, chauffe-eau en panne. Disponible 24h/24 à Juigny-sur-Orge.",
      image: "https://images.unsplash.com/photo-1585704032915-c3400ca199e7?w=1200&h=600&fit=crop",
      longDescription: "Une fuite d'eau ? Un robinet qui goutte ? Un WC bouché ? Notre équipe de plombiers professionnels intervient rapidement pour tous vos dépannages urgents. Disponible 24h/24 et 7j/7, nous garantissons une intervention en moins de 30 minutes à Juigny-sur-Orge et dans les communes environnantes.",
      features: [
        "Intervention en 30 minutes",
        "Disponible 24h/24 et 7j/7",
        "Devis gratuit avant travaux",
        "Garantie 1 an pièces et main-d'œuvre",
        "Toutes marques de robinetterie",
        "Détection et réparation de fuites",
      ],
    },
    {
      slug: "installation-sanitaire",
      title: "Installation sanitaire",
      description: "Pose de lavabo, douche, baignoire, évier ou WC. Installation conforme aux normes avec matériel de qualité à Juigny-sur-Orge.",
      image: "https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?w=1200&h=600&fit=crop",
      longDescription: "Vous rénovez votre salle de bain ou cuisine ? Nous installons tous vos équipements sanitaires avec soin et dans le respect des normes en vigueur. Du simple remplacement de robinet à l'installation complète d'une salle de bain, nous vous accompagnons à chaque étape.",
      features: [
        "Conseil personnalisé",
        "Installation conforme aux normes",
        "Matériel de qualité",
        "Pose de lavabo, douche, baignoire",
        "Installation de WC suspendus",
        "Raccordement évier et lave-linge",
      ],
    },
    {
      slug: "chauffage-chaudiere",
      title: "Chauffage & chaudière",
      description: "Installation, entretien annuel et réparation de chaudières. Toutes marques. Devis gratuit à Juigny-sur-Orge et en Île-de-France.",
      image: "https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=1200&h=600&fit=crop",
      longDescription: "Pour votre confort toute l'année, nous assurons l'installation, l'entretien annuel obligatoire et la réparation de vos chaudières et systèmes de chauffage. Intervenant sur toutes les marques, nous vous aidons à réduire votre consommation d'énergie tout en maintenant une température optimale.",
      features: [
        "Toutes marques de chaudières",
        "Entretien annuel obligatoire",
        "Réparation rapide",
        "Conseil économies d'énergie",
        "Installation de thermostat",
        "Détartrage et nettoyage",
      ],
    },
    {
      slug: "debouchage-canalisation",
      title: "Débouchage canalisation",
      description: "Débouchage efficace de vos canalisations avec équipements professionnels. Caméra d'inspection et hydrocurage à Juigny-sur-Orge.",
      image: "https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=1200&h=600&fit=crop",
      longDescription: "Canalisation bouchée, évier qui se vide lentement, mauvaises odeurs : nos plombiers utilisent des équipements professionnels pour un débouchage efficace et durable. Grâce à notre caméra d'inspection, nous identifions précisément l'origine du problème pour une intervention ciblée.",
      features: [
        "Caméra d'inspection",
        "Hydrocurage haute pression",
        "Détection des fuites",
        "Débouchage mécanique",
        "Nettoyage et entretien",
        "Devis gratuit",
      ],
    },
    {
      slug: "renovation-salle-de-bain",
      title: "Rénovation salle de bain",
      description: "Rénovation complète ou partielle de votre salle de bain. Design sur mesure, travaux clés en main à Juigny-sur-Orge.",
      image: "https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?w=1200&h=600&fit=crop",
      longDescription: "Vous souhaitez transformer votre salle de bain ? Nous proposons des solutions de rénovation complètes et sur mesure. Du simple remplacement de baignoire à la rénovation totale incluant la plomberie, l'électricité et le carrelage, nous gérons votre projet de A à Z avec un interlocuteur unique.",
      features: [
        "Design sur mesure",
        "Devis détaillé et transparent",
        "Travaux clés en main",
        "Conseil matériaux",
        "Installation complète",
        "Garantie décennale",
      ],
    },
    {
      slug: "detartrage-entretien",
      title: "Détartrage & entretien",
      description: "Entretien régulier de vos installations pour éviter les pannes. Contrat d'entretien disponible à Juigny-sur-Orge.",
      image: "https://images.unsplash.com/photo-1585704032915-c3400ca199e7?w=1200&h=600&fit=crop",
      longDescription: "L'entretien régulier de vos installations est essentiel pour éviter les pannes coûteuses et prolonger la durée de vie de vos équipements. Nous proposons des contrats d'entretien adaptés à vos besoins incluant le détartrage, le nettoyage et la vérification de vos installations.",
      features: [
        "Contrat d'entretien sur mesure",
        "Détartrage professionnel",
        "Conseils de prévention",
        "Vérification annuelle",
        "Réduction des pannes",
        "Économies d'énergie",
      ],
    },
  ];

  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout title={service.title} description={service.description}>
  <Header />

  <!-- Hero -->
  <section class="relative h-64 md:h-80">
    <img src={service.image} alt={service.title} class="w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-ink-deep/60"></div>
    <div class="absolute inset-0 flex items-center">
      <div class="container-custom">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-white max-w-2xl">{service.title}</h1>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="container-custom">
      <div class="grid lg:grid-cols-3 gap-10">
        <!-- Contenu principal -->
        <div class="lg:col-span-2 space-y-8">
          <div class="prose max-w-none">
            <p class="text-lg text-steel leading-relaxed">{service.longDescription}</p>
          </div>

          <div>
            <h2 class="text-2xl font-semibold text-ink-deep mb-4">Ce que nous proposons</h2>
            <ul class="grid sm:grid-cols-2 gap-3">
              {service.features.map((feature) => (
                <li class="flex items-start gap-3 bg-surface-soft rounded-lg p-4">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#31a24c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  <span class="text-steel">{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <div class="bg-surface-soft rounded-xl p-6">
            <h3 class="font-semibold text-ink-deep mb-4">Demander un devis</h3>
            <p class="text-steel text-sm mb-4">Obtenez un devis gratuit et sans engagement pour votre projet.</p>
            <a href="/contact" class="inline-flex items-center justify-center w-full bg-primary text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-deep transition-colors">
              Devis gratuit
            </a>
          </div>

          <div class="bg-accent/10 rounded-xl p-6 border border-accent/20">
            <h3 class="font-semibold text-accent-deep mb-2">Urgence ?</h3>
            <p class="text-steel text-sm mb-4">Notre équipe est disponible 24h/24 pour les dépannages urgents.</p>
            <a href="tel:+33123456789" class="inline-flex items-center justify-center w-full bg-accent text-white font-semibold px-6 py-3 rounded-lg hover:bg-accent-deep transition-colors">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"></path>
              </svg>
              01 23 45 67 89
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
