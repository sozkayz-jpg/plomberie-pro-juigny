---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact" description="Contactez Plomberie Pro Juigny pour un devis gratuit ou une intervention d'urgence. Disponible 24h/24 à Juigny-sur-Orge et en Île-de-France.">
  <Header />

  <section class="bg-surface-soft py-16 md:py-24">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center space-y-6 mb-16">
        <h1 class="text-hero font-semibold text-ink-deep">Contactez-nous</h1>
        <p class="text-lg text-steel leading-relaxed">
          Besoin d'un devis gratuit ou d'une intervention d'urgence ? Notre équipe est à votre écoute 24h/24 et 7j/7.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Informations de contact -->
        <div class="space-y-8">
          <div class="bg-white rounded-xl p-6 shadow-sm border border-hairline-soft">
            <h2 class="text-xl font-semibold text-ink-deep mb-4">Nos coordonnées</h2>
            <div class="space-y-4">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0057b7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-ink-deep">Téléphone</p>
                  <a href="tel:+33123456789" class="text-steel hover:text-primary transition-colors">01 23 45 67 89</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0057b7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-ink-deep">Email</p>
                  <a href="mailto:contact@plomberiepro.fr" class="text-steel hover:text-primary transition-colors">contact@plomberiepro.fr</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0057b7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-ink-deep">Adresse</p>
                  <p class="text-steel">12 Rue de la République<br />91640 Juigny-sur-Orge</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0057b7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-ink-deep">Horaires</p>
                  <p class="text-steel">Disponible 24h/24 et 7j/7</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-hairline-soft">
            <h2 class="text-xl font-semibold text-ink-deep mb-4">Intervention d'urgence</h2>
            <p class="text-steel mb-4">Pour toute urgence plomberie, contactez-nous directement par téléphone. Nous intervenons en moins de 30 minutes.</p>
            <a href="tel:+33123456789" class="inline-flex items-center gap-2 bg-accent text-white font-semibold px-6 py-3 rounded-full hover:bg-accent-deep transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"></path>
              </svg>
              Appeler maintenant
            </a>
          </div>
        </div>

        <!-- Formulaire -->
        <div class="bg-white rounded-xl p-6 md:p-8 shadow-sm border border-hairline-soft">
          <h2 class="text-xl font-semibold text-ink-deep mb-6">Demander un devis gratuit</h2>
          <form action="#" method="POST" class="space-y-5">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="prenom" class="block text-sm font-medium text-ink-deep mb-1">Prénom *</label>
                <input type="text" id="prenom" name="prenom" required class="w-full px-4 py-3 rounded-lg border border-hairline focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" placeholder="Votre prénom" />
              </div>
              <div>
                <label for="nom" class="block text-sm font-medium text-ink-deep mb-1">Nom *</label>
                <input type="text" id="nom" name="nom" required class="w-full px-4 py-3 rounded-lg border border-hairline focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" placeholder="Votre nom" />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="email" class="block text-sm font-medium text-ink-deep mb-1">Email *</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-hairline focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" placeholder="votre@email.fr" />
              </div>
              <div>
                <label for="telephone" class="block text-sm font-medium text-ink-deep mb-1">Téléphone</label>
                <input type="tel" id="telephone" name="telephone" class="w-full px-4 py-3 rounded-lg border border-hairline focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" placeholder="01 23 45 67 89" />
              </div>
            </div>

            <div>
              <label for="ville" class="block text-sm font-medium text-ink-deep mb-1">Ville d'intervention *</label>
              <input type="text" id="ville" name="ville" required class="w-full px-4 py-3 rounded-lg border border-hairline focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" placeholder="Ex : Juigny-sur-Orge" />
            </div>

            <div>
              <label for="service" class="block text-sm font-medium text-ink-deep mb-1">Type de service *</label>
              <select id="service" name="service" required class="w-full px-4 py-3 rounded-lg border border-hairline focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all bg-white">
                <option value="">Sélectionnez un service</option>
                <option value="depannage">Dépannage plomberie</option>
                <option value="installation">Installation sanitaire</option>
                <option value="chauffage">Chauffage & chaudière</option>
                <option value="debouchage">Débouchage canalisation</option>
                <option value="renovation">Rénovation salle de bain</option>
                <option value="entretien">Détartrage & entretien</option>
                <option value="autre">Autre</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-ink-deep mb-1">Description du besoin *</label>
              <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 rounded-lg border border-hairline focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-y" placeholder="Décrivez votre besoin..."></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input type="checkbox" id="rgpd" name="rgpd" required class="mt-1 w-4 h-4 text-primary border-hairline rounded focus:ring-primary" />
              <label for="rgpd" class="text-sm text-steel">
                J'accepte que mes données personnelles soient utilisées pour être recontacté concernant ma demande. <a href="/politique-de-confidentialite" class="text-primary hover:underline">Politique de confidentialité</a>.
              </label>
            </div>

            <button type="submit" class="w-full bg-primary text-white font-semibold px-6 py-4 rounded-lg hover:bg-primary-deep transition-colors">
              Envoyer ma demande
            </button>

            <p class="text-xs text-steel text-center">*Nous vous recontactons sous 24h ouvrées.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
