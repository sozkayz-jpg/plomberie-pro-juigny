---
interface Props {
  title: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className = "" } = Astro.props;
---

<section class={`py-16 md:py-20 lg:py-24 ${className}`}>
  <div class="container-custom">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="text-heading md:text-display font-semibold text-ink-deep mb-4">{title}</h2>
      {subtitle && (
        <p class="text-lg text-steel">{subtitle}</p>
      )}
    </div>
    <slot />
  </div>
</section>
